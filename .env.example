# Copy to .env.local and fill in real values. Do not commit .env.local.

# OpenAI — used by lib/llm.ts for criteria extraction, resume parsing, scoring.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase — used by lib/supabase.ts (server-only) and scripts/seed-supabase.ts.
# Both come from your Supabase project's API Keys settings page:
#   https://supabase.com/dashboard/project/<your-project>/settings/api-keys
#
# SUPABASE_SECRET_KEY is the new-format secret key (`sb_secret_...`) that
# replaces the legacy `service_role` JWT (announced 2025; legacy keys removed
# from new projects in Nov 2025). It bypasses Row-Level Security and must
# NEVER ship to the client bundle. lib/supabase.ts has `import "server-only"`
# to enforce this at build time.
#
# If you're on a legacy project that still has a `service_role` JWT, that
# value works here too — the Supabase client accepts both formats.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Auth — hardcoded credentials that gate the recruiter-facing parts of the app.
# AUTH_USER / AUTH_PASS are the credentials shown to recruiters.
# AUTH_SECRET signs the session cookie (HMAC-SHA256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Anyone with AUTH_SECRET can mint valid session cookies, so treat it like a
# secret. The /apply public form does NOT require auth — applicants submit
# without an account.
AUTH_USER=
AUTH_PASS=
AUTH_SECRET=
